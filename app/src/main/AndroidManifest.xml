<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.bulliongrin.app">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/app_icon"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BullionGrin">

        <activity
            android:name=".ui.activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.activities.AddContributionActivity"
            android:label="Add Contribution"
            android:parentActivityName=".ui.activities.MainActivity" />

        <activity
            android:name=".ui.activities.RecordsActivity"
            android:label="Savings Records"
            android:parentActivityName=".ui.activities.MainActivity" />

        <activity
            android:name=".ui.activities.SettingsActivity"
            android:label="Settings"
            android:parentActivityName=".ui.activities.MainActivity" />

    </application>

</manifest>
